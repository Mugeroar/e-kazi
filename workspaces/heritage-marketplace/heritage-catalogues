<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
  <title>WhatsApp Catalogues | Heritage Marketplace</title>
  
  <meta name="theme-color" content="#d97706">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  
  <link rel="icon" type="image/png" href="https://i.postimg.cc/rFfXDj3L/kazinni-removebg-preview(1).png">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&display=swap" rel="stylesheet">
  
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --amber: #d97706;
      --amber-dark: #92400e;
      --amber-light: #fbbf24;
      --card-bg: #ffffff;
      --text-primary: #1e293b;
      --text-muted: #64748b;
      --border-light: #fde68a;
      --success: #10b981;
      --warning: #f59e0b;
      --danger: #ef4444;
      --info: #3b82f6;
      --purple: #8b5cf6;
    }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      background: linear-gradient(145deg, #fffbeb 0%, #ffffff 100%);
      color: var(--text-primary);
      line-height: 1.4;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    @keyframes shimmer {
      0% { background-position: -200% 0; }
      100% { background-position: 200% 0; }
    }
    .skeleton {
      background: linear-gradient(90deg, #e5e7eb 25%, #f3f4f6 50%, #e5e7eb 75%);
      background-size: 200% 100%;
      animation: shimmer 1.5s ease-in-out infinite;
      border-radius: 6px;
    }
    .skeleton-text { height: 1rem; margin-bottom: 0.5rem; }
    .skeleton-text-sm { height: 0.7rem; width: 60%; }
    .skeleton-image { height: 140px; border-radius: 0; }
    .skeleton-title { height: 1.1rem; width: 70%; margin-bottom: 0.4rem; }
    .skeleton-desc { height: 0.85rem; width: 90%; margin-bottom: 0.3rem; }
    .skeleton-badge { height: 22px; width: 60px; border-radius: 10px; }
    .skeleton-card {
      background: white; border-radius: 16px; overflow: hidden;
      border: 1px solid #f3f4f6; box-shadow: 0 2px 8px rgba(0,0,0,0.02);
    }

    .navbar {
      background: rgba(255, 255, 255, 0.95);
      backdrop-filter: blur(16px);
      padding: 0.5rem 2%;
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-bottom: 1px solid rgba(217, 119, 6, 0.2);
      position: sticky;
      top: 0;
      z-index: 100;
      flex-wrap: wrap;
      gap: 8px;
    }

    .logo { display: flex; align-items: center; gap: 10px; text-decoration: none; }
    .logo-img { height: 34px; width: 34px; border-radius: 10px; object-fit: contain; background: white; box-shadow: 0 4px 12px rgba(217, 119, 6, 0.2); }
    .logo-text {
      font-weight: 800; font-size: 1.1rem;
      background: linear-gradient(145deg, #fbbf24, #d97706);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    }
    .logo-text span { font-weight: 600; font-size: 0.7rem; background: #92400e; -webkit-text-fill-color: #92400e; margin-left: 3px; }

    .nav-right { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
    .nav-btn {
      background: rgba(217, 119, 6, 0.08); border: 1px solid rgba(217, 119, 6, 0.2);
      padding: 0.4rem 0.8rem; border-radius: 25px; color: var(--amber-dark);
      font-weight: 600; font-size: 0.7rem; cursor: pointer; display: inline-flex;
      align-items: center; gap: 5px; text-decoration: none; transition: all 0.2s;
    }
    .nav-btn:hover { background: var(--amber); color: white; }
    .nav-btn.active { background: var(--amber); color: white; border-color: var(--amber-dark); }

    .container { padding: 1rem 2%; flex: 1; }

    .page-header { margin-bottom: 1rem; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 0.8rem; }
    .page-header h1 { font-size: 1.3rem; font-weight: 800; color: #0f172a; }
    .page-header h1 i { color: var(--amber-dark); margin-right: 6px; }

    .stats-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; margin-bottom: 1rem; }
    .stat-mini {
      background: white; border-radius: 14px; padding: 0.8rem 1rem; text-align: center;
      border: 1px solid var(--border-light); box-shadow: 0 2px 8px rgba(217,119,6,0.03);
      transition: all 0.3s;
    }
    .stat-mini:hover { transform: translateY(-2px); box-shadow: 0 4px 12px rgba(217,119,6,0.08); }
    .stat-mini .stat-num { font-size: 1.4rem; font-weight: 800; color: var(--amber-dark); line-height: 1.1; }
    .stat-mini .stat-label { font-size: 0.6rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.3px; }

    .filter-bar { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 1rem; align-items: center; }
    .filter-btn {
      padding: 0.35rem 0.8rem; border-radius: 20px; border: 1.5px solid #e2e8f0;
      background: white; color: #64748b; font-weight: 600; font-size: 0.65rem;
      cursor: pointer; transition: all 0.15s; font-family: inherit;
    }
    .filter-btn:hover { border-color: var(--amber); color: var(--amber-dark); }
    .filter-btn.active { background: var(--amber); color: white; border-color: var(--amber); }
    .search-box { flex: 1; min-width: 150px; max-width: 300px; position: relative; }
    .search-box input {
      width: 100%; padding: 0.35rem 0.8rem 0.35rem 2rem; border-radius: 20px;
      border: 1.5px solid #e2e8f0; font-size: 0.7rem; font-family: 'Inter', sans-serif;
    }
    .search-box i { position: absolute; left: 8px; top: 50%; transform: translateY(-50%); color: #94a3b8; font-size: 0.7rem; }

    .btn {
      padding: 0.5rem 1rem; border-radius: 10px; border: none; font-weight: 700;
      font-size: 0.7rem; cursor: pointer; display: inline-flex; align-items: center;
      gap: 5px; font-family: inherit; transition: all 0.15s; white-space: nowrap;
    }
    .btn-primary { background: var(--amber); color: white; }
    .btn-primary:hover { background: var(--amber-dark); }
    .btn-secondary { background: #f1f5f9; color: #475569; }
    .btn-secondary:hover { background: #e2e8f0; }

    .cards-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 12px; }

    .catalogue-card {
      background: white; border-radius: 18px; overflow: hidden;
      border: 1px solid var(--border-light); box-shadow: 0 3px 12px rgba(217,119,6,0.03);
      transition: all 0.25s; cursor: pointer;
    }
    .catalogue-card:hover { transform: translateY(-3px); box-shadow: 0 8px 20px rgba(217,119,6,0.1); }
    
    .catalogue-cover {
      height: 150px; background: linear-gradient(135deg, #fffbeb, #fef3c7);
      display: flex; align-items: center; justify-content: center;
      font-size: 3rem; position: relative; overflow: hidden;
    }
    .catalogue-cover img { width: 100%; height: 100%; object-fit: cover; }
    .catalogue-status {
      position: absolute; top: 10px; right: 10px;
      padding: 0.2rem 0.6rem; border-radius: 10px;
      font-size: 0.6rem; font-weight: 700; color: white;
    }
    .status-sent { background: var(--info); }
    .status-draft { background: var(--warning); }
    .status-delivered { background: var(--success); }

    .catalogue-body { padding: 1rem 1.2rem; }
    .catalogue-body h3 { font-size: 0.95rem; font-weight: 700; margin-bottom: 0.3rem; }
    .catalogue-meta { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 0.6rem; }
    .meta-tag {
      font-size: 0.6rem; padding: 0.15rem 0.5rem; border-radius: 8px;
      font-weight: 600; background: #f1f5f9; color: #475569;
    }
    .meta-tag.partner { background: #fffbeb; color: #92400e; }
    .meta-tag.products { background: #f0fdf4; color: #065f46; }
    
    .catalogue-info { display: grid; grid-template-columns: 1fr 1fr; gap: 4px; font-size: 0.65rem; margin-bottom: 0.6rem; }
    .catalogue-info div { color: var(--text-muted); }
    .catalogue-info strong { color: var(--text-primary); display: block; font-size: 0.55rem; text-transform: uppercase; }

    .catalogue-actions { display: flex; gap: 4px; flex-wrap: wrap; }
    .btn-sm {
      padding: 0.3rem 0.6rem; border-radius: 8px; border: none; font-weight: 600;
      font-size: 0.6rem; cursor: pointer; display: inline-flex; align-items: center;
      gap: 3px; transition: all 0.15s; font-family: inherit;
    }
    .btn-edit { background: #fffbeb; color: #92400e; }
    .btn-edit:hover { background: #d97706; color: white; }
    .btn-view { background: #eff6ff; color: #1d4ed8; }
    .btn-view:hover { background: #3b82f6; color: white; }
    .btn-delete { background: #fee2e2; color: #991b1b; }
    .btn-delete:hover { background: #ef4444; color: white; }

    .empty-state { text-align: center; padding: 3rem; color: #94a3b8; grid-column: 1 / -1; }

    .modal-overlay {
      display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%;
      background: rgba(0,0,0,0.5); z-index: 3000; justify-content: center;
      align-items: center; backdrop-filter: blur(2px);
    }
    .modal-overlay.show { display: flex; }
    .modal {
      background: white; border-radius: 20px; padding: 1.5rem; max-width: 550px;
      width: 95%; max-height: 85vh; overflow-y: auto; box-shadow: 0 25px 50px rgba(0,0,0,0.2);
    }
    .modal h3 { font-size: 0.95rem; margin-bottom: 1rem; display: flex; align-items: center; gap: 8px; color: var(--amber-dark); }
    .form-group { margin-bottom: 0.7rem; }
    .form-group label {
      display: block; font-size: 0.65rem; font-weight: 700; color: var(--text-muted);
      text-transform: uppercase; letter-spacing: 0.3px; margin-bottom: 0.15rem;
    }
    .form-group input, .form-group select, .form-group textarea {
      width: 100%; padding: 0.5rem 0.7rem; border-radius: 10px;
      border: 1.5px solid #e2e8f0; font-size: 0.8rem; font-family: 'Inter', sans-serif;
      background: #f8fafc; transition: all 0.2s;
    }
    .form-group input:focus, .form-group select:focus, .form-group textarea:focus {
      outline: none; border-color: var(--amber); box-shadow: 0 0 0 3px rgba(217,119,6,0.1);
    }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 0.6rem; }
    .btn-row { display: flex; gap: 8px; margin-top: 1rem; }

    .toast {
      position: fixed; bottom: 25px; right: 25px; background: var(--amber); color: white;
      padding: 0.7rem 1.2rem; border-radius: 20px; font-weight: 600; z-index: 4000;
      animation: slideIn 0.3s ease; box-shadow: 0 8px 20px rgba(217,119,6,0.25);
      display: flex; align-items: center; gap: 6px; font-size: 0.75rem;
    }
    .toast.error { background: var(--danger); }
    @keyframes slideIn { from { transform: translateX(100%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }

    @media (max-width: 768px) {
      .stats-row { grid-template-columns: repeat(2, 1fr); }
      .cards-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

  <nav class="navbar">
    <a href="heritage-dashboard.html" class="logo">
      <img src="https://i.postimg.cc/rFfXDj3L/kazinni-removebg-preview(1).png" alt="Heritage" class="logo-img">
      <span class="logo-text">Heritage <span>Marketplace</span></span>
    </a>
    <div class="nav-right">
      <a href="heritage-dashboard.html" class="nav-btn"><i class="fas fa-arrow-left"></i> Dashboard</a>
      <a href="heritage-partners.html" class="nav-btn"><i class="fas fa-handshake"></i> Partners</a>
      <a href="heritage-products.html" class="nav-btn"><i class="fas fa-box"></i> Products</a>
      <a href="heritage-orders.html" class="nav-btn"><i class="fas fa-shopping-cart"></i> Orders</a>
      <a href="heritage-catalogues.html" class="nav-btn active"><i class="fas fa-images"></i> Catalogues</a>
    </div>
  </nav>

  <div class="container">
    <div class="page-header">
      <h1><i class="fas fa-images"></i> WhatsApp Catalogues</h1>
      <button class="btn btn-primary" onclick="showAddModal()"><i class="fas fa-plus"></i> New Catalogue</button>
    </div>

    <!-- Stats Row -->
    <div class="stats-row" id="statsRow">
      <div class="stat-mini"><div class="skeleton" style="height:1.4rem;width:50%;margin:0 auto 0.3rem;"></div><div class="skeleton" style="height:0.6rem;width:60%;margin:0 auto;"></div></div>
      <div class="stat-mini"><div class="skeleton" style="height:1.4rem;width:50%;margin:0 auto 0.3rem;"></div><div class="skeleton" style="height:0.6rem;width:60%;margin:0 auto;"></div></div>
      <div class="stat-mini"><div class="skeleton" style="height:1.4rem;width:50%;margin:0 auto 0.3rem;"></div><div class="skeleton" style="height:0.6rem;width:60%;margin:0 auto;"></div></div>
      <div class="stat-mini"><div class="skeleton" style="height:1.4rem;width:50%;margin:0 auto 0.3rem;"></div><div class="skeleton" style="height:0.6rem;width:60%;margin:0 auto;"></div></div>
    </div>

    <!-- Filter Bar -->
    <div class="filter-bar">
      <button class="filter-btn active" data-filter="all">All</button>
      <button class="filter-btn" data-filter="sent">📤 Sent</button>
      <button class="filter-btn" data-filter="draft">📝 Draft</button>
      <button class="filter-btn" data-filter="delivered">✅ Delivered</button>
      <div class="search-box">
        <i class="fas fa-search"></i>
        <input type="text" id="searchInput" placeholder="Search catalogues...">
      </div>
    </div>

    <!-- Catalogues Grid -->
    <div class="cards-grid" id="cataloguesGrid">
      <div class="skeleton-card"><div class="skeleton skeleton-image"></div><div style="padding:1rem 1.2rem;"><div class="skeleton skeleton-title"></div><div class="skeleton skeleton-desc"></div><div class="skeleton skeleton-desc" style="width:60%;"></div><div style="display:flex;gap:6px;margin-top:0.5rem;"><div class="skeleton skeleton-badge"></div><div class="skeleton skeleton-badge" style="width:50px;"></div></div><div style="display:flex;gap:6px;margin-top:0.6rem;"><div class="skeleton" style="height:28px;width:60px;border-radius:8px;"></div><div class="skeleton" style="height:28px;width:60px;border-radius:8px;"></div></div></div></div>
      <div class="skeleton-card"><div class="skeleton skeleton-image"></div><div style="padding:1rem 1.2rem;"><div class="skeleton skeleton-title"></div><div class="skeleton skeleton-desc"></div><div class="skeleton skeleton-desc" style="width:60%;"></div><div style="display:flex;gap:6px;margin-top:0.5rem;"><div class="skeleton skeleton-badge"></div><div class="skeleton skeleton-badge" style="width:50px;"></div></div><div style="display:flex;gap:6px;margin-top:0.6rem;"><div class="skeleton" style="height:28px;width:60px;border-radius:8px;"></div><div class="skeleton" style="height:28px;width:60px;border-radius:8px;"></div></div></div></div>
      <div class="skeleton-card"><div class="skeleton skeleton-image"></div><div style="padding:1rem 1.2rem;"><div class="skeleton skeleton-title"></div><div class="skeleton skeleton-desc"></div><div class="skeleton skeleton-desc" style="width:60%;"></div><div style="display:flex;gap:6px;margin-top:0.5rem;"><div class="skeleton skeleton-badge"></div><div class="skeleton skeleton-badge" style="width:50px;"></div></div><div style="display:flex;gap:6px;margin-top:0.6rem;"><div class="skeleton" style="height:28px;width:60px;border-radius:8px;"></div><div class="skeleton" style="height:28px;width:60px;border-radius:8px;"></div></div></div></div>
    </div>
  </div>

  <div class="modal-overlay" id="modal"><div class="modal" id="modalContent"></div></div>
  <div id="toastContainer"></div>

  <script src="https://www.gstatic.com/firebasejs/10.8.0/firebase-app-compat.js"></script>
  <script src="https://www.gstatic.com/firebasejs/10.8.0/firebase-database-compat.js"></script>
  <script src="https://www.gstatic.com/firebasejs/10.8.0/firebase-auth-compat.js"></script>

  <script>
    const firebaseConfig = {
      apiKey: "AIzaSyC7kppUyHUaPzeLBV62NEZWuHiuz1Kz0mA",
      authDomain: "mugera-e51cc.firebaseapp.com",
      databaseURL: "https://mugera-e51cc-default-rtdb.europe-west1.firebasedatabase.app",
      projectId: "mugera-e51cc",
      storageBucket: "mugera-e51cc.firebasestorage.app",
      messagingSenderId: "1024868637509",
      appId: "1:1024868637509:web:321faecddce8f11d9cfc2c"
    };

    firebase.initializeApp(firebaseConfig);
    const database = firebase.database();
    const auth = firebase.auth();

    let allCatalogues = {};
    let allPartners = {};
    let allProducts = {};
    let currentFilter = 'all';
    let searchQuery = '';

    function showToast(msg, isError = false) {
      const container = document.getElementById('toastContainer');
      const existing = container.querySelector('.toast');
      if (existing) existing.remove();
      const toast = document.createElement('div');
      toast.className = `toast ${isError ? 'error' : ''}`;
      toast.innerHTML = `<i class="fas fa-${isError ? 'exclamation-circle' : 'check-circle'}"></i> ${msg}`;
      container.appendChild(toast);
      setTimeout(() => toast.remove(), 3500);
    }

    function escapeHtml(str) {
      if (!str) return '';
      return String(str).replace(/[&<>]/g, m => m === '&' ? '&amp;' : m === '<' ? '&lt;' : m === '>' ? '&gt;' : m);
    }

    function getPartnerName(partnerId) {
      if (!partnerId) return 'N/A';
      const partner = allPartners[partnerId];
      return partner ? (partner.businessName || partner.name || 'Partner') : partnerId;
    }

    function getStatusClass(status) {
      const map = { sent: 'status-sent', draft: 'status-draft', delivered: 'status-delivered' };
      return map[status] || 'status-draft';
    }

    function updateStats() {
      const catalogues = Object.values(allCatalogues);
      const total = catalogues.length;
      const sent = catalogues.filter(c => c.status === 'sent').length;
      const draft = catalogues.filter(c => c.status === 'draft' || !c.status).length;
      const delivered = catalogues.filter(c => c.status === 'delivered').length;

      document.getElementById('statsRow').innerHTML = 
        `<div class="stat-mini"><div class="stat-num">${total}</div><div class="stat-label">Total Catalogues</div></div>` +
        `<div class="stat-mini"><div class="stat-num">${sent}</div><div class="stat-label">Sent</div></div>` +
        `<div class="stat-mini"><div class="stat-num">${draft}</div><div class="stat-label">Drafts</div></div>` +
        `<div class="stat-mini"><div class="stat-num">${delivered}</div><div class="stat-label">Delivered</div></div>`;
    }

    function renderCatalogues() {
      const grid = document.getElementById('cataloguesGrid');
      let catalogues = Object.entries(allCatalogues).map(([id, data]) => ({ id, ...data }));

      if (currentFilter !== 'all') {
        catalogues = catalogues.filter(c => (c.status || 'draft') === currentFilter);
      }

      if (searchQuery) {
        const q = searchQuery.toLowerCase();
        catalogues = catalogues.filter(c => 
          (c.name || '').toLowerCase().includes(q) ||
          getPartnerName(c.partnerId).toLowerCase().includes(q)
        );
      }

      if (!catalogues.length) {
        grid.innerHTML = '<div class="empty-state"><i class="fas fa-images" style="font-size:2rem;display:block;margin-bottom:8px;opacity:0.4;"></i><p>No catalogues found</p></div>';
        return;
      }

      grid.innerHTML = catalogues.map(c => {
        const partnerName = getPartnerName(c.partnerId);
        const status = c.status || 'draft';
        const productCount = (c.productIds || []).length;
        const coverImage = c.coverImage || '';
        const icon = coverImage ? '' : '📱';

        return `
          <div class="catalogue-card" onclick="viewCatalogue('${c.id}')">
            <div class="catalogue-cover">
              ${coverImage ? `<img src="${escapeHtml(coverImage)}" alt="${escapeHtml(c.name)}" onerror="this.style.display='none';this.parentElement.innerHTML='<span style=font-size:3rem;>📱</span>';">` : icon}
              <span class="catalogue-status ${getStatusClass(status)}">${status}</span>
            </div>
            <div class="catalogue-body">
              <h3>${escapeHtml(c.name || 'Catalogue')}</h3>
              <div class="catalogue-meta">
                <span class="meta-tag partner"><i class="fas fa-handshake"></i> ${escapeHtml(partnerName)}</span>
                <span class="meta-tag products"><i class="fas fa-box"></i> ${productCount} products</span>
              </div>
              <div class="catalogue-info">
                <div><strong>Created</strong>${c.createdAt ? new Date(c.createdAt).toLocaleDateString() : 'N/A'}</div>
                <div><strong>Sent To</strong>${c.sentTo || 'N/A'}</div>
                <div><strong>Platform</strong>${c.platform || 'WhatsApp'}</div>
                <div><strong>Updated</strong>${c.updatedAt ? new Date(c.updatedAt).toLocaleDateString() : 'N/A'}</div>
              </div>
              ${c.notes ? `<p style="font-size:0.65rem;color:var(--text-muted);margin-bottom:0.5rem;">📝 ${escapeHtml(c.notes.substring(0, 60))}${c.notes.length > 60 ? '...' : ''}</p>` : ''}
              <div class="catalogue-actions" onclick="event.stopPropagation()">
                <button class="btn-sm btn-edit" onclick="editCatalogue('${c.id}')"><i class="fas fa-edit"></i> Edit</button>
                <button class="btn-sm btn-view" onclick="viewCatalogue('${c.id}')"><i class="fas fa-eye"></i> View</button>
                <button class="btn-sm btn-delete" onclick="deleteCatalogue('${c.id}')"><i class="fas fa-trash"></i> Delete</button>
              </div>
            </div>
          </div>`;
      }).join('');

      updateStats();
    }

    function showAddModal() {
      const partners = Object.entries(allPartners).filter(([_, p]) => p && (p.businessName || p.name));
      const products = Object.entries(allProducts).filter(([_, p]) => p && p.name);

      document.getElementById('modalContent').innerHTML = `
        <h3><i class="fas fa-plus-circle"></i> New WhatsApp Catalogue</h3>
        <div class="form-group"><label>Catalogue Name *</label><input type="text" id="cName" placeholder="e.g., Weekly Deals Catalogue"></div>
        <div class="form-row">
          <div class="form-group"><label>Business Partner *</label><select id="cPartner">
            <option value="">— Select Partner —</option>
            ${partners.map(([id, p]) => `<option value="${id}">${escapeHtml(p.businessName || p.name)}</option>`).join('')}
          </select></div>
          <div class="form-group"><label>Status</label><select id="cStatus">
            <option value="draft">📝 Draft</option>
            <option value="sent">📤 Sent</option>
            <option value="delivered">✅ Delivered</option>
          </select></div>
        </div>
        <div class="form-group"><label>Select Products</label>
          <div style="max-height:150px;overflow-y:auto;border:1px solid #e2e8f0;border-radius:10px;padding:0.5rem;">
            ${products.map(([id, p]) => `
              <label style="display:flex;align-items:center;gap:6px;padding:0.3rem 0;font-size:0.75rem;cursor:pointer;">
                <input type="checkbox" value="${id}" class="product-checkbox"> ${escapeHtml(p.name)} — KES ${(p.price || 0).toLocaleString()}
              </label>
            `).join('')}
            ${products.length === 0 ? '<p style="color:var(--text-muted);text-align:center;padding:1rem;">No products available</p>' : ''}
          </div>
        </div>
        <div class="form-row">
          <div class="form-group"><label>Sent To</label><input type="text" id="cSentTo" placeholder="Phone or name"></div>
          <div class="form-group"><label>Platform</label><select id="cPlatform">
            <option value="WhatsApp">WhatsApp</option>
            <option value="Instagram">Instagram</option>
            <option value="Facebook">Facebook</option>
            <option value="Email">Email</option>
          </select></div>
        </div>
        <div class="form-group"><label>Cover Image URL</label><input type="text" id="cCoverImage" placeholder="https://... (optional)"></div>
        <div class="form-group"><label>Notes</label><textarea id="cNotes" rows="2" placeholder="Any notes about this catalogue..."></textarea></div>
        <div class="btn-row">
          <button class="btn btn-primary" onclick="saveCatalogue()"><i class="fas fa-save"></i> Save Catalogue</button>
          <button class="btn btn-secondary" onclick="closeModal()">Cancel</button>
        </div>
      `;
      document.getElementById('modal').classList.add('show');
    }

    async function saveCatalogue() {
      const name = document.getElementById('cName').value.trim();
      const partnerId = document.getElementById('cPartner').value;
      if (!name) { showToast('Catalogue name is required', true); return; }
      if (!partnerId) { showToast('Select a business partner', true); return; }

      const productIds = [...document.querySelectorAll('.product-checkbox:checked')].map(cb => cb.value);

      try {
        await database.ref('heritage_catalogues').push().set({
          name,
          partnerId,
          productIds,
          status: document.getElementById('cStatus').value,
          sentTo: document.getElementById('cSentTo').value.trim(),
          platform: document.getElementById('cPlatform').value,
          coverImage: document.getElementById('cCoverImage').value.trim(),
          notes: document.getElementById('cNotes').value.trim(),
          createdAt: firebase.database.ServerValue.TIMESTAMP,
          updatedAt: firebase.database.ServerValue.TIMESTAMP
        });
        showToast('✅ Catalogue created!');
        closeModal();
      } catch (e) { showToast('Failed to save', true); }
    }

    function editCatalogue(catalogueId) {
      const c = allCatalogues[catalogueId];
      if (!c) return;
      const partners = Object.entries(allPartners).filter(([_, p]) => p && (p.businessName || p.name));
      const products = Object.entries(allProducts).filter(([_, p]) => p && p.name);
      const selectedProducts = c.productIds || [];

      document.getElementById('modalContent').innerHTML = `
        <h3><i class="fas fa-edit"></i> Edit Catalogue</h3>
        <div class="form-group"><label>Catalogue Name</label><input type="text" id="ecName" value="${escapeHtml(c.name || '')}"></div>
        <div class="form-row">
          <div class="form-group"><label>Business Partner</label><select id="ecPartner">
            ${partners.map(([id, p]) => `<option value="${id}" ${c.partnerId === id ? 'selected' : ''}>${escapeHtml(p.businessName || p.name)}</option>`).join('')}
          </select></div>
          <div class="form-group"><label>Status</label><select id="ecStatus">
            ${['draft','sent','delivered'].map(s => `<option value="${s}" ${c.status === s ? 'selected' : ''}>${s === 'draft' ? '📝 Draft' : s === 'sent' ? '📤 Sent' : '✅ Delivered'}</option>`).join('')}
          </select></div>
        </div>
        <div class="form-group"><label>Select Products</label>
          <div style="max-height:150px;overflow-y:auto;border:1px solid #e2e8f0;border-radius:10px;padding:0.5rem;">
            ${products.map(([id, p]) => `
              <label style="display:flex;align-items:center;gap:6px;padding:0.3rem 0;font-size:0.75rem;cursor:pointer;">
                <input type="checkbox" value="${id}" class="product-checkbox" ${selectedProducts.includes(id) ? 'checked' : ''}> ${escapeHtml(p.name)} — KES ${(p.price || 0).toLocaleString()}
              </label>
            `).join('')}
          </div>
        </div>
        <div class="form-row">
          <div class="form-group"><label>Sent To</label><input type="text" id="ecSentTo" value="${escapeHtml(c.sentTo || '')}"></div>
          <div class="form-group"><label>Platform</label><select id="ecPlatform">
            ${['WhatsApp','Instagram','Facebook','Email'].map(p => `<option value="${p}" ${c.platform === p ? 'selected' : ''}>${p}</option>`).join('')}
          </select></div>
        </div>
        <div class="form-group"><label>Cover Image URL</label><input type="text" id="ecCoverImage" value="${escapeHtml(c.coverImage || '')}"></div>
        <div class="form-group"><label>Notes</label><textarea id="ecNotes" rows="2">${escapeHtml(c.notes || '')}</textarea></div>
        <div class="btn-row">
          <button class="btn btn-primary" onclick="updateCatalogue('${catalogueId}')"><i class="fas fa-save"></i> Update</button>
          <button class="btn btn-secondary" onclick="closeModal()">Cancel</button>
        </div>
      `;
      document.getElementById('modal').classList.add('show');
    }

    async function updateCatalogue(catalogueId) {
      try {
        const productIds = [...document.querySelectorAll('.product-checkbox:checked')].map(cb => cb.value);
        await database.ref(`heritage_catalogues/${catalogueId}`).update({
          name: document.getElementById('ecName').value.trim(),
          partnerId: document.getElementById('ecPartner').value,
          productIds,
          status: document.getElementById('ecStatus').value,
          sentTo: document.getElementById('ecSentTo').value.trim(),
          platform: document.getElementById('ecPlatform').value,
          coverImage: document.getElementById('ecCoverImage').value.trim(),
          notes: document.getElementById('ecNotes').value.trim(),
          updatedAt: firebase.database.ServerValue.TIMESTAMP
        });
        showToast('✅ Updated!');
        closeModal();
      } catch (e) { showToast('Failed to update', true); }
    }

    function viewCatalogue(catalogueId) {
      const c = allCatalogues[catalogueId];
      if (!c) return;
      const partnerName = getPartnerName(c.partnerId);
      const status = c.status || 'draft';
      const productIds = c.productIds || [];
      const productsList = productIds.map(pid => {
        const p = allProducts[pid];
        return p ? `<div style="display:flex;justify-content:space-between;padding:0.4rem 0;border-bottom:1px solid #f3f4f6;font-size:0.75rem;"><span>${escapeHtml(p.name)}</span><span style="font-weight:600;">KES ${(p.price || 0).toLocaleString()}</span></div>` : '';
      }).join('');

      document.getElementById('modalContent').innerHTML = `
        <h3><i class="fas fa-eye"></i> ${escapeHtml(c.name || 'Catalogue')}</h3>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;font-size:0.75rem;margin-bottom:1rem;">
          <div><strong>Partner:</strong> ${escapeHtml(partnerName)}</div>
          <div><strong>Status:</strong> <span class="catalogue-status ${getStatusClass(status)}">${status}</span></div>
          <div><strong>Platform:</strong> ${escapeHtml(c.platform || 'WhatsApp')}</div>
          <div><strong>Sent To:</strong> ${escapeHtml(c.sentTo || 'N/A')}</div>
          <div><strong>Products:</strong> ${productIds.length} items</div>
          <div><strong>Updated:</strong> ${c.updatedAt ? new Date(c.updatedAt).toLocaleDateString() : 'N/A'}</div>
        </div>
        <div style="margin-bottom:1rem;"><strong>Products in Catalogue:</strong></div>
        <div style="max-height:200px;overflow-y:auto;margin-bottom:1rem;">${productsList || '<p style="color:var(--text-muted);">No products</p>'}</div>
        ${c.notes ? `<div style="background:#fffbeb;padding:0.6rem;border-radius:8px;font-size:0.7rem;margin-bottom:1rem;"><strong>📝 Notes:</strong> ${escapeHtml(c.notes)}</div>` : ''}
        <div class="btn-row">
          <button class="btn btn-primary" onclick="closeModal();editCatalogue('${catalogueId}')"><i class="fas fa-edit"></i> Edit</button>
          <button class="btn btn-secondary" onclick="closeModal()">Close</button>
        </div>
      `;
      document.getElementById('modal').classList.add('show');
    }

    async function deleteCatalogue(catalogueId) {
      if (!confirm('Delete this catalogue?')) return;
      try {
        await database.ref(`heritage_catalogues/${catalogueId}`).remove();
        showToast('✅ Deleted');
      } catch (e) { showToast('Failed to delete', true); }
    }

    function closeModal() { document.getElementById('modal').classList.remove('show'); }

    // Filters
    document.querySelectorAll('.filter-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        currentFilter = btn.dataset.filter;
        renderCatalogues();
      });
    });

    document.getElementById('searchInput').addEventListener('input', (e) => {
      searchQuery = e.target.value;
      renderCatalogues();
    });

    document.getElementById('modal').addEventListener('click', (e) => {
      if (e.target === document.getElementById('modal')) closeModal();
    });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });

    // Firebase listeners
    database.ref('heritage_catalogues').on('value', (snapshot) => {
      allCatalogues = snapshot.val() || {};
      renderCatalogues();
    });

    database.ref('heritage_partners').on('value', (snapshot) => {
      allPartners = snapshot.val() || {};
      renderCatalogues();
    });

    database.ref('heritage_products').on('value', (snapshot) => {
      allProducts = snapshot.val() || {};
      renderCatalogues();
    });

    auth.onAuthStateChanged((user) => { if (!user) window.location.href = '/'; });

    window.showAddModal = showAddModal;
    window.editCatalogue = editCatalogue;
    window.viewCatalogue = viewCatalogue;
    window.deleteCatalogue = deleteCatalogue;
    window.saveCatalogue = saveCatalogue;
    window.updateCatalogue = updateCatalogue;
    window.closeModal = closeModal;
  </script>
</body>
</html>
