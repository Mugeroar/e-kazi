        const totalBizEl = document.getElementById('totalBiz');
        const activeCountEl = document.getElementById('activeCount');
        const basicCountEl = document.getElementById('basicCount');
        const basicBadgeEl = document.getElementById('basicBadge');
        const recentListEl = document.getElementById('recentList');
        const lastUpdatedEl = document.getElementById('lastUpdated');
        const footerStatsEl = document.getElementById('footerStats');
        const repNameEl = document.getElementById('repName');
        const repAvatarEl = document.getElementById('repAvatar');

        // Format timestamp to relative time
        function formatRelativeTime(timestamp) {
            if (!timestamp) return '';
            
            let date;
            if (typeof timestamp === 'string') {
                date = new Date(timestamp);
            } else if (typeof timestamp === 'number') {
                date = new Date(timestamp);
            } else {
                return '';
            }
            
            if (isNaN(date.getTime())) return '';
            
            const now = new Date();
            const diff = now - date;
            const seconds = Math.floor(diff / 1000);
            const minutes = Math.floor(seconds / 60);
            const hours = Math.floor(minutes / 60);
            const days = Math.floor(hours / 24);
            
            if (days > 30) return '';
            if (days > 0) return `${days}d ago`;
            if (hours > 0) return `${hours}h ago`;
            if (minutes > 0) return `${minutes}m ago`;
            return 'Just now';
        }

        // Get business icon
        function getBusinessIcon(businessName) {
            const name = (businessName || '').toLowerCase();
            if (name.includes('craft')) return 'fa-paint-brush';
            if (name.includes('furniture')) return 'fa-couch';
            if (name.includes('shoe') || name.includes('step')) return 'fa-shoe-prints';
            if (name.includes('food')) return 'fa-utensils';
            if (name.includes('wood')) return 'fa-tree';
            return 'fa-store';
        }

        // Get initials
        function getInitials(name) {
            if (!name) return 'BN';
            return name.split(' ').map(n => n[0]).join('').toUpperCase().substring(0, 2);
        }

        // Render recent list
        function renderRecentList() {
            const businesses = Object.entries(allBusinesses)
                .filter(([_, data]) => data && data.businessName)
                .map(([slug, data]) => ({
                    slug,
                    ...data
                }));
            
            if (businesses.length === 0) {
                recentListEl.innerHTML = `
                    <div class="empty-state">
                        <i class="fas fa-store-slash"></i>
                        <p>No businesses listed yet</p>
                        <a href="list-business.html" style="color:#7c3aed; text-decoration:none; font-weight:600; display:inline-block; margin-top:10px;">+ List your first business</a>
                    </div>
                `;
                return;
            }
            
            // Sort by createdAt (newest first)
            businesses.sort((a, b) => {
                const dateA = a.createdAt || 0;
                const dateB = b.createdAt || 0;
                return dateB - dateA;
            });
            
            // Take top 6
            const recent = businesses.slice(0, 6);
            
            recentListEl.innerHTML = recent.map(biz => {
                const status = biz.status || 'active';
                const statusClass = status === 'active' ? '' : 'inactive';
                const timeAgo = formatRelativeTime(biz.createdAt);
                const plan = biz.plan || 'basic';
                const planDisplay = plan === 'basic' ? 'Basic' : plan === 'professional' ? 'Pro' : plan === 'complete_branding' ? 'Complete' : plan;
                const email = biz.email || '—';
                const initials = getInitials(biz.businessName);
                
                return `
                    <div class="recent-item">
                        <div class="recent-info">
                            <div class="recent-icon">
                                <span style="font-weight:700; font-size:1rem;">${initials}</span>
                            </div>
                            <div class="recent-details">
                                <h4>${biz.businessName}</h4>
                                <p>${email} • ${planDisplay} plan ${timeAgo ? '• ' + timeAgo : ''}</p>
                            </div>
                        </div>
                        <span class="status-tag ${statusClass}">
                            <i class="fas fa-${status === 'active' ? 'check-circle' : 'clock'}"></i> 
                            ${status === 'active' ? 'Active' : status}
                        </span>
                    </div>
                `;
            }).join('');
        }

        // Update stats
        function updateStats() {
            const businesses = Object.values(allBusinesses).filter(b => b && b.businessName);
            
            const totalBusinesses = businesses.length;
            const activeBusinesses = businesses.filter(b => b.status === 'active' || !b.status).length;
            const basicPlanCount = businesses.filter(b => (b.plan || 'basic') === 'basic').length;
            
            // Update UI
            totalBizEl.textContent = totalBusinesses;
            activeCountEl.textContent = activeBusinesses;
            basicCountEl.textContent = basicPlanCount;
            basicBadgeEl.textContent = basicPlanCount;
            
            // Update trends
            document.getElementById('totalTrend').innerHTML = `<i class="fas fa-database"></i> All registered`;
            document.getElementById('activeTrend').innerHTML = `<i class="fas fa-check-circle"></i> Live on BrandInn`;
            document.getElementById('basicTrend').innerHTML = `<i class="fas fa-tag"></i> KSh 800/mo`;
            
            // Update footer
            footerStatsEl.textContent = `${totalBusinesses} total • ${activeBusinesses} active • ${basicPlanCount} basic plan`;
            
            // Update last updated
            const now = new Date();
            lastUpdatedEl.innerHTML = `<i class="fas fa-circle" style="color:#10b981;"></i> Live • ${now.toLocaleTimeString()}`;
            
            // Render recent list
            renderRecentList();
        }

        // Set up real-time listener for brandinn_subdomains ONLY
        function setupRealtimeListener() {
            const subdomainsRef = ref(db, 'brandinn_subdomains');
            
            onValue(subdomainsRef, (snapshot) => {
                allBusinesses = snapshot.val() || {};
                updateStats();
                loadingOverlay.classList.add('hide');
                console.log('📊 Data updated:', Object.keys(allBusinesses).length, 'businesses');
            }, (error) => {
                console.error('Error loading businesses:', error);
                loadingOverlay.classList.add('hide');
                recentListEl.innerHTML = `
                    <div class="empty-state">
                        <i class="fas fa-exclamation-triangle" style="color:#ef4444;"></i>
                        <p>Error loading data. Please refresh.</p>
                    </div>
                `;
            });
        }

        // Set up auth state
        onAuthStateChanged(auth, async (user) => {
            if (user) {
                // Get user data from database
                const userRef = ref(db, `brandinn_users/${user.uid}`);
                const userSnap = await get(userRef);
                
                let userName = 'Field Rep';
                if (userSnap.exists()) {
                    const userData = userSnap.val();
                    userName = userData.name || userData.displayName || user.email?.split('@')[0] || 'Field Rep';
                } else {
                    userName = user.displayName || user.email?.split('@')[0] || 'Field Rep';
                }
                
                currentUser = { uid: user.uid, email: user.email, name: userName };
                
                // Update UI
                repNameEl.textContent = userName;
                const initials = userName.split(' ').map(n => n[0]).join('').toUpperCase().substring(0, 2);
                repAvatarEl.textContent = initials || 'FR';
                
                // Set up real-time data
                setupRealtimeListener();
            } else {
                // No user signed in - still show data but mark as not signed in
                repNameEl.textContent = 'Guest Rep';
                repAvatarEl.textContent = 'GR';
                
                // Still load data for demo/viewing
                setupRealtimeListener();
            }
        });

        // Logout functionality
        document.getElementById('logoutBtn').addEventListener('click', async () => {
            if (confirm('Are you sure you want to log out?')) {
                try {
                    await signOut(auth);
                    window.location.href = 'login.html';
                } catch (error) {
                    console.error('Logout error:', error);
                    alert('Error logging out. Please try again.');
                }
            }
        });

        // Initial load timeout (hide loader after 5 seconds max)
        setTimeout(() => {
            loadingOverlay.classList.add('hide');
        }, 5000);
    </script>
</body>
</html>
