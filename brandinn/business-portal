<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>BrandInn Field Rep | Home</title>
    
    <!-- PWA Meta -->
    <meta name="theme-color" content="#7c3aed">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <link rel="manifest" href="data:application/json;base64,eyJuYW1lIjoiQnJhbmRJbm4gUmVwIiwic2hvcnRfbmFtZSI6IkJyYW5kSW5uIiwiZGlzcGxheSI6InN0YW5kYWxvbmUiLCJ0aGVtZV9jb2xvciI6IiM3YzNhZWQifQ==">
    
    <!-- Fonts & Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            background: linear-gradient(145deg, #f8f6fc 0%, #ffffff 100%);
            color: #1a1a2e;
            line-height: 1.5;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* Loading State */
        .loading-skeleton {
            background: linear-gradient(90deg, #f1f5f9 25%, #e2e8f0 50%, #f1f5f9 75%);
            background-size: 200% 100%;
            animation: shimmer 1.5s infinite;
            border-radius: 12px;
        }

        @keyframes shimmer {
            0% { background-position: 200% 0; }
            100% { background-position: -200% 0; }
        }

        /* Navigation */
        .navbar {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            padding: 0.9rem 5%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid rgba(124, 58, 237, 0.12);
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 14px;
        }

        .logo-icon {
            background: linear-gradient(135deg, #7c3aed, #a78bfa);
            width: 46px;
            height: 46px;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 1.5rem;
            box-shadow: 0 10px 20px rgba(124, 58, 237, 0.2);
        }

        .logo-text {
            font-weight: 800;
            font-size: 1.5rem;
            background: linear-gradient(145deg, #7c3aed, #8b5cf6);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            letter-spacing: -0.5px;
        }

        .logo-text span {
            font-weight: 500;
            font-size: 0.85rem;
            background: #64748b;
            -webkit-text-fill-color: #64748b;
            margin-left: 6px;
            letter-spacing: 0;
        }

        .nav-right {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .rep-profile {
            display: flex;
            align-items: center;
            gap: 14px;
            background: #f1f5f9;
            padding: 0.3rem 1rem 0.3rem 0.8rem;
            border-radius: 60px;
        }

        .rep-avatar {
            width: 42px;
            height: 42px;
            background: linear-gradient(145deg, #7c3aed, #c084fc);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 700;
            font-size: 1rem;
        }

        .rep-info {
            line-height: 1.3;
        }

        .rep-name {
            font-weight: 700;
            color: #0f172a;
        }

        .rep-role {
            font-size: 0.7rem;
            color: #7c3aed;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .logout-btn {
            background: white;
            border: 1.5px solid #e2e8f0;
            padding: 0.55rem 1.2rem;
            border-radius: 40px;
            color: #475569;
            font-weight: 500;
            font-size: 0.85rem;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: all 0.2s;
            white-space: nowrap;
        }

        .logout-btn:hover {
            background: #fee2e2;
            border-color: #ef4444;
            color: #ef4444;
        }

        .last-updated {
            font-size: 0.7rem;
            color: #94a3b8;
            display: flex;
            align-items: center;
            gap: 5px;
            margin-left: 10px;
        }

        .last-updated i {
            color: #10b981;
            font-size: 0.5rem;
        }

        /* Main Content */
        .container {
            max-width: 1300px;
            margin: 0 auto;
            padding: 2.5rem 5%;
            flex: 1;
            width: 100%;
        }

        /* Header Section */
        .page-header {
            margin-bottom: 2.5rem;
        }

        .page-header h1 {
            font-size: 2.3rem;
            font-weight: 800;
            letter-spacing: -0.02em;
            color: #0f172a;
            display: flex;
            align-items: center;
            gap: 15px;
            flex-wrap: wrap;
        }

        .page-header h1 i {
            color: #7c3aed;
            background: white;
            padding: 12px;
            border-radius: 18px;
            box-shadow: 0 8px 18px rgba(124, 58, 237, 0.08);
        }

        .page-header p {
            color: #475569;
            font-size: 1.05rem;
            margin-top: 0.5rem;
            margin-left: 72px;
        }

        /* Stats Cards */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 22px;
            margin-bottom: 2.5rem;
        }

        .stat-card {
            background: white;
            border-radius: 24px;
            padding: 1.6rem 1.8rem;
            border: 1px solid #f1eaff;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.02);
            transition: all 0.2s;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .stat-card:hover {
            box-shadow: 0 15px 30px rgba(124, 58, 237, 0.06);
            border-color: #d8c9ff;
        }

        .stat-left h4 {
            font-size: 0.85rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: #64748b;
            margin-bottom: 0.5rem;
        }

        .stat-number {
            font-size: 2.8rem;
            font-weight: 800;
            color: #0f172a;
            line-height: 1.1;
        }

        .stat-trend {
            font-size: 0.75rem;
            margin-top: 5px;
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .trend-up { color: #10b981; }
        .trend-warning { color: #f59e0b; }
        .trend-neutral { color: #7c3aed; }

        .stat-icon {
            width: 58px;
            height: 58px;
            background: #f5f0ff;
            border-radius: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #7c3aed;
            font-size: 1.7rem;
        }

        /* Main Action Cards - Now 3 cards */
        .action-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 25px;
            margin-bottom: 2.5rem;
        }

        .action-card {
            background: white;
            border-radius: 32px;
            padding: 2rem 1.8rem;
            border: 1px solid #f1eaff;
            box-shadow: 0 15px 35px -10px rgba(124, 58, 237, 0.06);
            transition: all 0.3s;
            text-decoration: none;
            color: inherit;
            display: block;
            cursor: pointer;
        }

        .action-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 30px 50px -15px rgba(124, 58, 237, 0.15);
            border-color: #c9b3ff;
        }

        .action-icon {
            width: 65px;
            height: 65px;
            background: linear-gradient(145deg, #f5f0ff, #ffffff);
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 1.5rem;
            color: #7c3aed;
            font-size: 2rem;
            border: 1px solid rgba(124, 58, 237, 0.2);
        }

        .action-card h2 {
            font-size: 1.6rem;
            font-weight: 800;
            margin-bottom: 0.5rem;
            letter-spacing: -0.02em;
            color: #0f172a;
        }

        .action-card p {
            color: #64748b;
            font-size: 0.9rem;
            margin-bottom: 1.5rem;
            line-height: 1.5;
        }

        .action-link {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-weight: 700;
            color: #7c3aed;
            font-size: 0.9rem;
        }

        .action-link i {
            transition: transform 0.2s;
        }

        .action-card:hover .action-link i {
            transform: translateX(5px);
        }

        /* Map card specific styling */
        .action-card.map-card .action-icon {
            color: #10b981;
            border-color: rgba(16, 185, 129, 0.2);
            background: linear-gradient(145deg, #ecfdf5, #ffffff);
        }

        .action-card.map-card .action-link {
            color: #10b981;
        }

        /* Quick Links Section */
        .quick-section {
            background: white;
            border-radius: 28px;
            padding: 1.8rem 2rem;
            border: 1px solid #f1eaff;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.02);
        }

        .quick-header {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 1.5rem;
        }

        .quick-header i {
            color: #7c3aed;
            font-size: 1.3rem;
            background: #f5f0ff;
            padding: 10px;
            border-radius: 14px;
        }

        .quick-header h3 {
            font-weight: 700;
            font-size: 1.2rem;
        }

        .quick-links {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
        }

        .quick-btn {
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            padding: 0.7rem 1.5rem;
            border-radius: 60px;
            color: #1e293b;
            font-weight: 500;
            font-size: 0.9rem;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            transition: all 0.2s;
        }

        .quick-btn i {
            color: #7c3aed;
        }

        .quick-btn:hover {
            background: #7c3aed;
            color: white;
            border-color: #7c3aed;
        }

        .quick-btn:hover i {
            color: white;
        }

        .quick-btn.map-quick i {
            color: #10b981;
        }

        .quick-btn.map-quick:hover {
            background: #10b981;
            border-color: #10b981;
        }

        .quick-btn.map-quick:hover i {
            color: white;
        }

        /* Recent Activity Preview */
        .recent-section {
            margin-top: 2rem;
        }

        .recent-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 1rem;
        }

        .recent-header h3 {
            font-weight: 700;
            font-size: 1.1rem;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .view-all {
            color: #7c3aed;
            font-weight: 600;
            text-decoration: none;
            font-size: 0.85rem;
        }

        .recent-list {
            background: white;
            border-radius: 20px;
            border: 1px solid #f1eaff;
            overflow: hidden;
        }

        .recent-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 1rem 1.5rem;
            border-bottom: 1px solid #f1f5f9;
        }

        .recent-item:last-child {
            border-bottom: none;
        }

        .recent-info {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .recent-icon {
            width: 42px;
            height: 42px;
            background: #f5f0ff;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #7c3aed;
        }

        .recent-details h4 {
            font-weight: 700;
            margin-bottom: 0.2rem;
        }

        .recent-details p {
            font-size: 0.8rem;
            color: #64748b;
        }

        .status-tag {
            padding: 0.25rem 0.9rem;
            border-radius: 30px;
            font-size: 0.7rem;
            font-weight: 700;
            background: #e6f7e6;
            color: #0d7c3f;
        }

        .status-tag.inactive {
            background: #f1f5f9;
            color: #64748b;
        }

        .empty-state {
            text-align: center;
            padding: 3rem;
            color: #94a3b8;
        }

        .empty-state i {
            font-size: 2.5rem;
            margin-bottom: 1rem;
            opacity: 0.5;
        }

        /* Footer */
        .footer {
            text-align: center;
            padding: 1.5rem;
            color: #94a3b8;
            font-size: 0.8rem;
            border-top: 1px solid #f1eaff;
            margin-top: 2rem;
        }

        /* Loading Overlay */
        .loading-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(255,255,255,0.8);
            backdrop-filter: blur(4px);
            display: flex;
            justify-content: center;
            align-items: center;
            z-index: 999;
        }

        .loading-overlay.hide {
            display: none;
        }

        .spinner {
            width: 50px;
            height: 50px;
            border: 3px solid #f1eaff;
            border-top-color: #7c3aed;
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        /* Responsive */
        @media (max-width: 1000px) {
            .action-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @media (max-width: 850px) {
            .action-grid {
                grid-template-columns: 1fr;
                gap: 20px;
            }
            
            .stats-grid {
                grid-template-columns: 1fr;
                gap: 15px;
            }
            
            .navbar {
                padding: 0.8rem 1.2rem;
            }
            
            .logo-text {
                font-size: 1.2rem;
            }
            
            .rep-role {
                display: none;
            }
            
            .container {
                padding: 1.5rem 1.2rem;
            }
            
            .page-header h1 {
                font-size: 1.8rem;
            }
            
            .page-header p {
                margin-left: 0;
                margin-top: 0.8rem;
            }
            
            .last-updated {
                margin-left: 0;
                margin-top: 5px;
            }
        }

        @media (max-width: 500px) {
            .rep-info {
                display: none;
            }
            
            .logout-btn span {
                display: none;
            }
            
            .logout-btn {
                padding: 0.55rem;
            }
            
            .action-card {
                padding: 1.5rem;
            }
            
            .action-card h2 {
                font-size: 1.3rem;
            }
            
            .stat-card {
                padding: 1.2rem 1.5rem;
            }
            
            .stat-number {
                font-size: 2.2rem;
            }
        }
    </style>
</head>
